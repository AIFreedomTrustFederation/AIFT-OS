	fmt.Println("  discovery")
	fmt.Println("  doctor")
	fmt.Println("  event-bus")
	fmt.Println("  events")
	fmt.Println("  federation")
	fmt.Println("  federation-build")
	fmt.Println("  graph")
	fmt.Println("  intelligence")
	fmt.Println("  kernel")
	fmt.Println("  kernel-registry")
	fmt.Println("  lifecycle")
	fmt.Println("  manifest")
	fmt.Println("  manual")
	fmt.Println("  mesh")
	fmt.Println("  modules")
	fmt.Println("  operator")
	fmt.Println("  patch-engine")
	fmt.Println("  plan")
	fmt.Println("  plugins")
	fmt.Println("  provider-registry")
	fmt.Println("  providers")
	fmt.Println("  registry")
	fmt.Println("  repo")
	fmt.Println("  runtime")
	fmt.Println("  scheduler")
	fmt.Println("  serve")
	fmt.Println("  service-contracts")
	fmt.Println("  services")
	fmt.Println("  start")
	fmt.Println("  status")
	fmt.Println("  sync")
	fmt.Println("  tick")
	fmt.Println("  verify")
	fmt.Println("  version")
	fmt.Println("  workflow")
}
