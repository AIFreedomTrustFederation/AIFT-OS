	fmt.Println("AIFT-OS Federation Control Plane")
	fmt.Println("")
	fmt.Println("Commands:")
	fmt.Println("  ai")
	fmt.Println("  build")
	fmt.Println("  capabilities")
	fmt.Println("  capability")
	fmt.Println("  cli-registry")
	fmt.Println("  compile")
	fmt.Println("  compiler")
	fmt.Println("  daemon")
	fmt.Println("  dashboard")
